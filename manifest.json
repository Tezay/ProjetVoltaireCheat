{
  "manifest_version": 3,
  "name": "Projet Voltaire Cheat (2026)",
  "version": "2.1.0",
  "description": "Assistant pour Projet Voltaire",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.projet-voltaire.fr/*"
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Projet Voltaire Cheat"
  },
  "icons": {
    "128": "./assets/icon.png"
  }
}
